# Non-secret Firebase Functions parameters.
# Copy to functions/.env only if you want deploy-time defaults.
# Store OPENAI_API_KEY with Firebase Secret Manager, not in this file.

OPENAI_CLASSIFIER_MODEL=gpt-5-nano
OPENAI_MODEL=gpt-5-nano
OPENAI_STRONG_MODEL=gpt-5.4-nano
OPENAI_FALLBACK_MODEL=gpt-5.4-mini
# GPT-5 Responses API: use minimal reasoning so cheap tasks return JSON instead of reasoning-only output.
OPENAI_REASONING_EFFORT=minimal

# Default is auth required. Set to 0 only for temporary local/emulator testing.
FORMA_AI_REQUIRE_AUTH=1

# Lightweight abuse guardrails (optional overrides; defaults are production-safe).
# FORMA_AI_MAX_BODY_BYTES=524288
# FORMA_AI_MAX_BODY_BYTES_WITH_IMAGE=2097152
# FORMA_AI_MAX_TEXT_CHARS=4000
# FORMA_AI_BURST_PER_MINUTE=30
# FORMA_AI_DAILY_REQUEST_LIMIT=400
