OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_CLASSIFIER_MODEL=
FITPILOT_AI_BACKEND_PORT=8787
# Bind on all interfaces so a physical iPhone on the same Wi‑Fi can reach the gateway.
FITPILOT_AI_BACKEND_HOST=0.0.0.0
# Gateway trace logging (JSON lines to stdout). Set VERBOSE=1 for body snippets.
FITPILOT_AI_BACKEND_TRACE=1
FITPILOT_AI_BACKEND_TRACE_VERBOSE=0
